checkedCount=document.querySelectorAll('.symptom-list li.checked').length;
const result=document.getElementById('symptomResult');
if(checkedCount>=2){result.classList.add('show')}else{result.classList.remove('show')}
}

// === FAQ ACCORDION ===
function toggleFaq(el){
